# ─── Obtén estos valores en Supabase → Settings → Database ───────────────────
# Connection string → URI  (la que dice "postgres://postgres:...")
DB_URL=postgres://postgres:[TU_PASSWORD]@db.[TU_PROJECT_REF].supabase.co:5432/postgres

# ─── Obtén estos valores en Supabase → Settings → API ────────────────────────
SUPABASE_URL=https://[TU_PROJECT_REF].supabase.co
# Service Role key (NO la anon key — esta tiene permisos de admin)
SUPABASE_SERVICE_KEY=eyJ...

# Contraseña que se asignará a todos los usuarios de prueba
TEST_PASSWORD=Escolar2025!
